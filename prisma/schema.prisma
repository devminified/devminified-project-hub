// Prisma schema for the Devminified Project Hub
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  APPROVED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String
  role         Role       @default(USER)
  // Signups start PENDING and can't sign in until an admin approves them.
  // Admin-created users default to APPROVED.
  status       UserStatus @default(APPROVED)
  projects     Project[]  @relation("ProjectAccess")
  // Per-project "dev" grants: lets this user edit a specific project's tab
  // content (details/envs/docs/readmes) without being a global admin.
  devRoles     ProjectDev[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum ProjectStatus {
  Production
  Staging
  Development
}

enum EnvScope {
  Production
  Preview
  Development
}

enum Component {
  FRONTEND
  BACKEND
  DB
}

// Which feature a project's tab belongs to. Docs, Envs, and READMEs each have
// their own independent, editable set of tabs (categories) per project.
enum TabFeature {
  DOC
  ENV
  ENV_SCOPE
  README
}

/**
 * A project-specific, editable tab (category) for one feature. Replaces the
 * fixed `Component` enum: each project seeds Frontend/Backend/DB per feature
 * and admins / project devs can add, rename, or remove tabs from there.
 */
model ProjectTab {
  id        String     @id @default(cuid())
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  feature   TabFeature
  name      String
  order     Int        @default(0)
  docs      Doc[]
  // Env vars use ProjectTab twice: once for the component tab, once for scope.
  envs      EnvVar[]   @relation("EnvTab")
  envScopes EnvVar[]   @relation("EnvScopeTab")
  readmes   Readme[]
  createdAt DateTime   @default(now())

  @@index([projectId, feature])
}

model Project {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  description   String
  status        ProjectStatus @default(Development)
  // Lifecycle flag: archived projects are hidden from the main listing and
  // shown only on the /archive page. Separate from `status` (deploy stage).
  archived      Boolean       @default(false)
  tags          String[]
  // Optional project image (data URL or external URL) shown on the card + hero.
  imageUrl      String?
  // Admin-editable detail sections: an array of { heading, links: [{ label, url }] }.
  // Lets each project expose any number of URL groups instead of a fixed pair.
  detailSections Json         @default("[]")
  // Admin-only secret sections: same shape as detailSections, but only ever
  // read/rendered for admins. Kept in its own column so it is never selected
  // alongside the non-sensitive project summary.
  secretSections Json         @default("[]")
  envs        EnvVar[]
  docs        Doc[]
  readmes     Readme[]
  // Per-project, per-feature editable tabs (categories).
  tabs        ProjectTab[]
  members     User[]        @relation("ProjectAccess")
  // Users granted the per-project "dev" role on this project.
  devs        ProjectDev[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

/**
 * A per-project "dev" grant. A row means `user` may edit `project`'s tab content
 * (details, envs, docs, readmes) — but never secrets or project settings, which
 * remain admin-only. Additive to the existing ProjectAccess membership.
 */
model ProjectDev {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

model EnvVar {
  id        String      @id @default(cuid())
  key       String
  value     String
  // Legacy fixed scope, superseded by `scopeTab`. Kept for backwards-compat.
  scope      EnvScope    @default(Development)
  // Legacy fixed category, superseded by `tab`. Kept for backwards-compat.
  component  Component?
  tab        ProjectTab? @relation("EnvTab", fields: [tabId], references: [id], onDelete: SetNull)
  tabId      String?
  scopeTab   ProjectTab? @relation("EnvScopeTab", fields: [scopeTabId], references: [id], onDelete: SetNull)
  scopeTabId String?
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String

  @@index([projectId])
  @@index([tabId])
  @@index([scopeTabId])
}

model Doc {
  id          String      @id @default(cuid())
  title       String
  description String
  // For file-backed docs (PDF / Word): Cloudinary URL + mime type. Null for
  // plain text/markdown docs, whose content lives in `description`.
  fileUrl     String?
  fileType    String?
  // Legacy fixed category, superseded by `tab`. Kept for backwards-compat.
  component   Component?
  tab         ProjectTab? @relation(fields: [tabId], references: [id], onDelete: SetNull)
  tabId       String?
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([projectId])
  @@index([tabId])
}

model Readme {
  id        String      @id @default(cuid())
  title     String
  content   String
  // For file-backed readmes (PDF / Word): Cloudinary URL + mime type. Null for
  // plain text/markdown readmes, whose content lives in `content`.
  fileUrl   String?
  fileType  String?
  // Legacy fixed category, superseded by `tab`. Kept for backwards-compat.
  component Component?
  tab       ProjectTab? @relation(fields: [tabId], references: [id], onDelete: SetNull)
  tabId     String?
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@index([projectId])
  @@index([tabId])
}
