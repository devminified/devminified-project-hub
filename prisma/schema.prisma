// Prisma schema for the Devminified Project Hub
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  APPROVED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String
  role         Role       @default(USER)
  // Signups start PENDING and can't sign in until an admin approves them.
  // Admin-created users default to APPROVED.
  status       UserStatus @default(APPROVED)
  projects     Project[]  @relation("ProjectAccess")
  // Per-project "dev" grants: lets this user edit a specific project's tab
  // content (details/envs/docs/readmes) without being a global admin.
  devRoles     ProjectDev[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum ProjectStatus {
  Production
  Staging
  Development
}

enum EnvScope {
  Production
  Preview
  Development
}

enum Component {
  FRONTEND
  BACKEND
  DB
}

model Project {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  description   String
  status        ProjectStatus @default(Development)
  tags          String[]
  // Optional project image (data URL or external URL) shown on the card + hero.
  imageUrl      String?
  // Admin-editable detail sections: an array of { heading, links: [{ label, url }] }.
  // Lets each project expose any number of URL groups instead of a fixed pair.
  detailSections Json         @default("[]")
  // Admin-only secret sections: same shape as detailSections, but only ever
  // read/rendered for admins. Kept in its own column so it is never selected
  // alongside the non-sensitive project summary.
  secretSections Json         @default("[]")
  envs        EnvVar[]
  docs        Doc[]
  readmes     Readme[]
  members     User[]        @relation("ProjectAccess")
  // Users granted the per-project "dev" role on this project.
  devs        ProjectDev[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

/**
 * A per-project "dev" grant. A row means `user` may edit `project`'s tab content
 * (details, envs, docs, readmes) — but never secrets or project settings, which
 * remain admin-only. Additive to the existing ProjectAccess membership.
 */
model ProjectDev {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

model EnvVar {
  id        String     @id @default(cuid())
  key       String
  value     String
  scope     EnvScope   @default(Development)
  component Component?
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@index([projectId])
}

model Doc {
  id          String     @id @default(cuid())
  title       String
  description String
  component   Component?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
}

model Readme {
  id        String     @id @default(cuid())
  title     String
  content   String
  component Component?
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@index([projectId])
}
